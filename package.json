{
  "name": "accesslint",
  "private": true,
  "packageManager": "bun@1.3.12",
  "workspaces": [
    "core",
    "cli",
    "mcp",
    "playwright",
    "storybook-addon",
    "vitest"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ci": "turbo run build typecheck test && bun run lint && bun run format:check"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.0",
    "publint": "^0.3.18",
    "turbo": "latest",
    "typescript-eslint": "^8.20.0"
  }
}

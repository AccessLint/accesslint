{
  "name": "@accesslint/core",
  "version": "0.8.8",
  "description": "Pure accessibility rule engine — WCAG audit with zero browser dependencies",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./iife": "./dist/index.iife.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown && vite build --config vite.iife.config.ts && publint && attw --pack --exclude-entrypoints ./iife",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project unit",
    "test:browser": "vitest run --project browser",
    "test:coverage": "vitest run --project unit --coverage",
    "test:memory": "vitest run --project memory",
    "act": "echo 'ACT conformance suite complete'",
    "act:fixtures": "scripts/download-act-fixtures.sh && npx tsx src/act/download-fixtures.ts",
    "act:test": "npx playwright test src/act/act-browser.spec.ts",
    "act:check": "npx tsx src/act/check-conformance.ts",
    "prepublishOnly": "npm run build",
    "release": "scripts/release.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AccessLint/core.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitest/browser": "4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "4.1.4",
    "happy-dom": "^20.9.0",
    "tsdown": "^0.21.9",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "4.1.4"
  }
}

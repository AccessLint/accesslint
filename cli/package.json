{
  "name": "@accesslint/cli",
  "version": "0.11.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AccessLint/accesslint.git",
    "directory": "cli"
  },
  "description": "CLI tool for auditing HTML accessibility using @accesslint/core",
  "type": "module",
  "bin": {
    "accesslint": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/safe-fetch.js",
    "./cdp-audit": "./dist/cdp-audit.js",
    "./ssrf-guard": "./dist/ssrf-guard.js",
    "./safe-fetch": "./dist/safe-fetch.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "dev": "bun src/cli.ts",
    "test": "vitest run",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@accesslint/chrome": "workspace:*",
    "@accesslint/core": "workspace:*",
    "chrome-remote-interface": "^0.34.0"
  },
  "devDependencies": {
    "@accesslint/heal-diff": "workspace:*",
    "@accesslint/matchers-internal": "workspace:*",
    "@types/chrome-remote-interface": "^0.33.0",
    "@types/node": "^25.3.0",
    "citty": "^0.1.6",
    "tsdown": "^0.21.9",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "license": "MIT"
}

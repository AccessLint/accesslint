{
  "name": "@accesslint/storybook-addon",
  "version": "0.8.10",
  "description": "Catch accessibility violations in your Storybook stories as you develop",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://www.accesslint.com/storybook?ref=npm_storybook",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AccessLint/storybook-addon.git"
  },
  "bugs": {
    "url": "https://github.com/AccessLint/core/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./manager": {
      "types": "./dist/manager.d.ts",
      "default": "./dist/manager.js"
    },
    "./preview": {
      "import": {
        "types": "./dist/preview.d.ts",
        "default": "./dist/preview.js"
      },
      "require": {
        "types": "./dist/preview.d.cts",
        "default": "./dist/preview.cjs"
      }
    },
    "./vitest-plugin": {
      "import": {
        "types": "./dist/vitest-plugin.d.ts",
        "default": "./dist/vitest-plugin.js"
      },
      "require": {
        "types": "./dist/vitest-plugin.d.cts",
        "default": "./dist/vitest-plugin.cjs"
      }
    },
    "./vitest-setup": {
      "import": {
        "types": "./dist/vitest-setup.d.ts",
        "default": "./dist/vitest-setup.js"
      },
      "require": {
        "types": "./dist/vitest-setup.d.cts",
        "default": "./dist/vitest-setup.cjs"
      }
    },
    "./matchers": {
      "import": {
        "types": "./dist/matchers.d.ts",
        "default": "./dist/matchers.js"
      },
      "require": {
        "types": "./dist/matchers.d.cts",
        "default": "./dist/matchers.cjs"
      }
    },
    "./portable": {
      "import": {
        "types": "./dist/portable.d.ts",
        "default": "./dist/portable.js"
      },
      "require": {
        "types": "./dist/portable.d.cts",
        "default": "./dist/portable.cjs"
      }
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.cts",
  "typesVersions": {
    "*": {
      "manager": ["./dist/manager.d.ts"],
      "preview": ["./dist/preview.d.ts"],
      "vitest-plugin": ["./dist/vitest-plugin.d.ts"],
      "vitest-setup": ["./dist/vitest-setup.d.ts"],
      "matchers": ["./dist/matchers.d.ts"],
      "portable": ["./dist/portable.d.ts"]
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "*.js",
    "*.d.ts"
  ],
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@accesslint/core": "workspace:*",
    "@accesslint/vitest": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "^10.2.0",
    "tsdown": "^0.21.9",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "storybook": "^9.0.0 || ^10.0.0",
    "vitest": ">=3.0.0"
  },
  "keywords": [
    "storybook-addon",
    "accessibility",
    "a11y",
    "wcag",
    "aria",
    "accesslint",
    "test",
    "component",
    "react",
    "vue",
    "angular",
    "svelte",
    "web-components"
  ],
  "storybook": {
    "displayName": "AccessLint",
    "icon": "https://accesslint.com/icon.png"
  },
  "bundler": {
    "managerEntries": [
      "./src/manager.tsx"
    ],
    "previewEntries": [
      "./src/preview.ts",
      "./src/index.ts"
    ]
  }
}

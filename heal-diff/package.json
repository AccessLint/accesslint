{
  "name": "@accesslint/heal-diff",
  "version": "0.1.0",
  "description": "Multi-signal diff engine for baseline/current sets with tiered matching, auto-healing, and likely-moved detection.",
  "license": "MIT",
  "type": "module",
  "files": ["dist"],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./normalize": {
      "import": {
        "types": "./dist/normalize.d.ts",
        "default": "./dist/normalize.js"
      },
      "require": {
        "types": "./dist/normalize.d.cts",
        "default": "./dist/normalize.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsdown": "^0.21.9",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}

{
  "name": "@accesslint/mcp",
  "version": "0.7.2",
  "description": "MCP server for accessible agentic coding — WCAG audit tools for AI coding agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "accesslint-mcp": "./bin/accesslint-mcp.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "bun run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AccessLint/accesslint.git",
    "directory": "mcp"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@accesslint/cli": "workspace:*",
    "@accesslint/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chrome-launcher": "^1.2.1",
    "chrome-remote-interface": "^0.34.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/chrome-remote-interface": "^0.33.0",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsdown": "^0.21.9",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}

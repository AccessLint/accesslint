{
  "name": "@accesslint/diff",
  "version": "0.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AccessLint/accesslint.git",
    "directory": "diff"
  },
  "description": "Diff accessibility violations of a set of routes between two builds (baseline vs candidate) over CDP",
  "type": "module",
  "bin": {
    "accesslint-diff": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "dev": "bun src/cli.ts",
    "test": "vitest run",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@accesslint/cli": "workspace:*",
    "@accesslint/core": "workspace:*",
    "@accesslint/matchers-internal": "workspace:*",
    "chrome-remote-interface": "^0.34.0"
  },
  "devDependencies": {
    "@types/chrome-remote-interface": "^0.33.0",
    "@types/node": "^25.3.0",
    "citty": "^0.1.6",
    "tsdown": "^0.21.9",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "license": "MIT"
}

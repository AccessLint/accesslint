{
  "name": "@accesslint/vitest",
  "version": "0.3.1",
  "description": "Accessibility assertions for Vitest — toBeAccessible() matcher powered by AccessLint",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AccessLint/accesslint.git",
    "directory": "vitest"
  },
  "bugs": {
    "url": "https://github.com/AccessLint/accesslint/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./matchers": {
      "import": {
        "types": "./dist/matchers.d.ts",
        "default": "./dist/matchers.js"
      },
      "require": {
        "types": "./dist/matchers.d.cts",
        "default": "./dist/matchers.cjs"
      }
    },
    "./fixture": {
      "import": {
        "types": "./dist/fixture.d.ts",
        "default": "./dist/fixture.js"
      },
      "require": {
        "types": "./dist/fixture.d.cts",
        "default": "./dist/fixture.cjs"
      }
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "*.d.ts"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@accesslint/core": "workspace:*"
  },
  "devDependencies": {
    "@accesslint/matchers-internal": "workspace:*",
    "happy-dom": "^20.6.1",
    "tsdown": "^0.21.9",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "vitest": ">=2.0.0"
  },
  "keywords": [
    "vitest",
    "accessibility",
    "a11y",
    "wcag",
    "aria",
    "accesslint",
    "matcher",
    "testing"
  ]
}
